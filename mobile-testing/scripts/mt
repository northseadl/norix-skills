#!/usr/bin/env bash
# mt — Mobile Testing CLI entry point
# Routes subcommands to Python scripts in the same directory.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
    cat <<'EOF'
Mobile Testing CLI

Usage: ./mt <command> [options]

Commands:
  devices                     List all connected Android/iOS devices
  perf                        Collect performance metrics and generate report
  capture                     Screenshot / screen recording / visual comparison
  logs                        Log monitoring with crash/ANR detection

Options:
  -h, --help                  Show this help message

Examples:
  ./mt devices
  ./mt perf --package com.example.app --platform android --samples 5
  ./mt capture --platform android --output /tmp/screenshot.png
  ./mt capture --compare /tmp/before.png /tmp/after.png --output /tmp/diff.md
  ./mt logs --package com.example.app --platform android --duration 30
EOF
}

if [[ $# -lt 1 ]]; then
    usage
    exit 1
fi

COMMAND="$1"
shift

case "$COMMAND" in
    devices)
        python3 "$SCRIPT_DIR/mt_core.py" "$@"
        ;;
    perf)
        python3 "$SCRIPT_DIR/perf.py" "$@"
        ;;
    capture)
        python3 "$SCRIPT_DIR/capture.py" "$@"
        ;;
    logs)
        python3 "$SCRIPT_DIR/logmon.py" "$@"
        ;;
    -h|--help)
        usage
        ;;
    *)
        echo "Error: Unknown command '$COMMAND'" >&2
        echo "Run './mt --help' for usage." >&2
        exit 1
        ;;
esac
