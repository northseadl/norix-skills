#!/bin/sh
# ─── Pre-Commit Hook: 禁止直接在 main 分支提交 ──────────────────────
#
# 规则: main 只接受来自 develop 的 merge，不允许直接 commit。
# 跳过: GIT_MERGE_COMMIT=1 环境变量（merge 操作自动设置）

BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null)

if [ "$BRANCH" = "main" ]; then
  # Allow merge commits (git merge sets GIT_REFLOG_ACTION)
  if [ -f "$(git rev-parse --git-dir)/MERGE_HEAD" ]; then
    exit 0
  fi

  echo ""
  echo "  ❌  禁止直接在 main 分支提交"
  echo ""
  echo "  main 只接受来自 develop 的合并:"
  echo "    git checkout main"
  echo "    git merge develop --no-ff"
  echo "    git push origin main"
  echo ""
  echo "  日常开发请在 develop 分支工作。"
  echo ""
  exit 1
fi
