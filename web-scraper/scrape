#!/usr/bin/env bash
# Web Scraper — Unified CLI entry point
# Engine: L0 (httpx, pure HTTP) → L1 (crawl4ai, Playwright browser)
# Usage: ./scrape <command> [args...]

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SCRIPTS_DIR="$SCRIPT_DIR/scripts"
VENV_DIR="$SCRIPTS_DIR/.venv"
PYTHON="$VENV_DIR/bin/python"

# Auto-setup on first run
if [[ ! -f "$PYTHON" ]]; then
    echo "⏳ First run: setting up Python environment..." >&2

    # Require uv
    UV="${UV:-$(command -v uv 2>/dev/null || echo "$HOME/.local/bin/uv")}"
    if [[ ! -x "$UV" ]]; then
        echo "ERROR: uv not found. Install with: curl -LsSf https://astral.sh/uv/install.sh | sh" >&2
        exit 1
    fi

    # Create venv + install deps
    (cd "$SCRIPTS_DIR" && "$UV" sync --quiet 2>&1) || {
        echo "ERROR: Failed to install dependencies. Run manually:" >&2
        echo "  cd $SCRIPTS_DIR && uv sync" >&2
        exit 1
    }

    # Install Playwright browser
    "$PYTHON" -m playwright install chromium --quiet 2>/dev/null || \
    "$PYTHON" -m playwright install chromium 2>&1 | tail -1

    echo "✅ Setup complete." >&2
fi

show_help() {
    cat <<'EOF'
Web Scraper — Scrape, analyze & extract content from any website

ENGINE: L0 (httpx, pure HTTP) → L1 (crawl4ai, Playwright browser)
        HTTP-first for speed. Browser fallback for SPAs and anti-bot sites.

USAGE:
    ./scrape <command> [options]

COMMANDS:
    discover <url>     Analyze page structure, detect framework, list links
    fetch <url>        Fetch page(s) and convert to Markdown
    exec <url>         Execute JavaScript on a page
    openapi <url>      Discover and convert OpenAPI/Swagger spec to Markdown

DISCOVER OPTIONS:
    --links-only       Only list discovered navigation links
    --sitemap          Build a directory tree of the site
    --deep             Follow links to discover more pages (crawl)
    --max-pages N      Max pages to discover (default: 200)
    --max-depth N      Max crawl depth (default: 3)
    --wait MS          Wait time for SPA rendering in ms (default: 2000)
    --json             Output results as JSON
    --engine MODE      Engine: auto (default), http, cdp

FETCH OPTIONS:
    --auto             Auto-discover pages then fetch all
    --from-file FILE   Read URLs from a file (one per line)
    -o, --output PATH  Output directory or file path
    --merge            Merge all pages into a single file
    --max-lines N      Max lines per page (0 = unlimited)
    --max-pages N      Max pages in auto mode (default: 50)
    --wait MS          Wait time for SPA rendering in ms (default: 2000)
    --summary-only     Only show fetch summary
    --json             Output results as JSON
    --engine MODE      Engine: auto (default), http, cdp
    --raw              Output full page (skip content filtering)
    --selector CSS     CSS selector for content area (precision mode)
    --js CODE          JavaScript to execute before content extraction
    --js-file PATH     JavaScript file to execute before extraction
    --wait-for CSS     Wait for CSS selector to appear before extraction
    --expand-all       Auto-expand collapsed/folded sections
    --scroll-full      Scroll entire page to trigger lazy loading

EXEC OPTIONS:
    --js CODE          JavaScript to execute on the page
    --js-file PATH     JavaScript file to execute
    --then-fetch       After JS execution, also fetch page as markdown
    --session ID       Reuse browser session for multi-step interactions
    --js-only          Skip navigation, execute JS on existing session
    -o, --output PATH  Output directory or file path
    --raw              Output full page (skip content filtering)

OPENAPI OPTIONS:
    -o, --output FILE  Output markdown file path

EXAMPLES:
    ./scrape discover https://docs.example.com
    ./scrape discover https://docs.example.com --deep --max-pages 100
    ./scrape fetch https://open.feishu.cn/document/server-docs/im-v1/message/create
    ./scrape fetch https://docs.example.com --auto --merge -o ./docs/all-docs.md
    ./scrape fetch --from-file urls.txt -o ./docs/
    ./scrape fetch URL --expand-all --wait 5000 -o ./docs/
    ./scrape fetch URL --js "document.querySelectorAll('.btn').forEach(e => e.click())"
    ./scrape exec URL --js "return document.title"
    ./scrape exec URL --js "expandAll()" --then-fetch -o result.md
    ./scrape openapi https://petstore.swagger.io/v2/swagger.json -o api.md

REQUIREMENTS:
    - uv (Python package manager): curl -LsSf https://astral.sh/uv/install.sh | sh
    - Dependencies auto-installed on first run
EOF
}

CMD="${1:-help}"

case "$CMD" in
    discover|fetch|exec|openapi)
        exec "$PYTHON" "$SCRIPTS_DIR/scrape_cli.py" "$@"
        ;;
    help|--help|-h)
        show_help
        ;;
    *)
        echo "ERROR: Unknown command '$CMD'. Run './scrape help' for usage." >&2
        exit 1
        ;;
esac
