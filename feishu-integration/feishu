#!/usr/bin/env bash
# feishu — Unified CLI for Feishu Integration (TypeScript)
# Usage: ./feishu <module> <command> [options]
#
# Modules:
#   auth     Authentication (login, relogin, refresh, status)
#   task     Task management (create, list, update, complete)
#   doc      Document & Drive (create, read, append, export, search)
#   wiki     Knowledge base (space, node, search, export)
#   bitable  多维表格 (table, record, field, export)
#   msg      Messaging (send, chats, history)
#   approval Approval workflows (create, approve, reject)
#   member   Member directory (scan, find, whoami)

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")/scripts" && pwd)"

exec node "$SCRIPT_DIR/feishu-cli.cjs" "$@"
